function initTerminal(win) {
  setTimeout(()=>{
    const inp=win.querySelector('#term-input'); if(!inp) return;
    inp.focus();
    inp.addEventListener('keydown',e=>{
      if(e.key!=='Enter') return;
      const cmd=inp.value.trim(); inp.value='';
      const lines=win.querySelector('#term-lines');
      const echo=document.createElement('div'); echo.className='terminal-line';
      echo.innerHTML=`<span class="t-prompt">user</span><span class="t-out">@</span><span class="t-path">helvOS</span><span class="t-out"> ~ %</span><span style="color:#f0ece6"> ${cmd}</span>`;
      lines.appendChild(echo);
      if(cmd==='') return;
      const out=document.createElement('div'); out.className='terminal-line';
      const resp={
        help:`<span class="t-out">Commands: help, ls, pwd, whoami, uname, date, clear, echo</span>`,
        ls:`<span class="t-out">Documents&nbsp;&nbsp;Downloads&nbsp;&nbsp;Pictures&nbsp;&nbsp;Music&nbsp;&nbsp;Projects</span>`,
        pwd:`<span class="t-out">/home/user</span>`,
        whoami:`<span class="t-out">user</span>`,
        uname:`<span class="t-out">helvOS Red Forest 0.0.5 Demo x86</span>`,
        date:`<span class="t-out">${new Date().toDateString()}</span>`,
      };
      if(cmd==='clear'){lines.innerHTML='';return;}
      else if(cmd.startsWith('echo ')) out.innerHTML=`<span class="t-out">${cmd.slice(5)}</span>`;
      else if(resp[cmd]) out.innerHTML=resp[cmd];
      else out.innerHTML=`<span class="t-err">helv: command not found: ${cmd}</span>`;
      lines.appendChild(out);
      win.querySelector('#term-body').scrollTop=9999;
    });
  },50);
}

