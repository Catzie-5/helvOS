const openWins = {};
let zCtr = 10;

function openWindow(id) {
  if(openWins[id]){ focusWin(openWins[id]); return; }
  const def = winDefs[id]; if(!def) return;
  const area = document.getElementById('desktop-area');
  const aw = area.clientWidth, ah = area.clientHeight;
  const ww = Math.min(def.w, aw-20), wh = Math.min(def.h, ah-20);
  const offset = Object.keys(openWins).length * 22;
  const w = document.createElement('div');
  w.className='window focused'; w.dataset.id=id;
  w.style.cssText=`width:${ww}px;height:${wh}px;left:${Math.min(60+offset,aw-ww-10)}px;top:${Math.min(20+offset,ah-wh-10)}px;z-index:${++zCtr}`;
  w.innerHTML=`
    <div class="window-bar">
      <div class="traffic-lights">
        <div class="tl close" onclick="closeWin('${id}')"></div>
        <div class="tl min"></div>
        <div class="tl max"></div>
      </div>
      <div class="window-title">${def.title}</div>
    </div>
    <div class="window-content">${def.content()}</div>`;
  // Touch drag
  const bar = w.querySelector('.window-bar');
  let dragging=false,ox=0,oy=0,startX=0,startY=0;
  bar.addEventListener('touchstart',e=>{
    if(e.target.classList.contains('tl')) return;
    focusWin(w); dragging=true;
    ox=w.offsetLeft; oy=w.offsetTop;
    startX=e.touches[0].clientX; startY=e.touches[0].clientY;
    e.preventDefault();
  },{passive:false});
  document.addEventListener('touchmove',e=>{
    if(!dragging) return;
    const dx=e.touches[0].clientX-startX, dy=e.touches[0].clientY-startY;
    w.style.left=(ox+dx)+'px'; w.style.top=(oy+dy)+'px';
    e.preventDefault();
  },{passive:false});
  document.addEventListener('touchend',()=>dragging=false);
  // Mouse drag
  bar.addEventListener('mousedown',e=>{
    if(e.target.classList.contains('tl')) return;
    focusWin(w);
    let mx=e.clientX-w.offsetLeft, my=e.clientY-w.offsetTop;
    const mm=ev=>{w.style.left=(ev.clientX-mx)+'px';w.style.top=(ev.clientY-my)+'px';};
    const mu=()=>{document.removeEventListener('mousemove',mm);document.removeEventListener('mouseup',mu);};
    document.addEventListener('mousemove',mm); document.addEventListener('mouseup',mu);
  });
  w.addEventListener('mousedown',()=>focusWin(w));
  w.addEventListener('touchstart',()=>focusWin(w),{passive:true});
  area.appendChild(w);
  openWins[id]=w;
  const dot=document.getElementById('dot-'+id); if(dot) dot.classList.add('visible');
  if(id==='terminal') initTerminal(w);
  if(id==='settings') initSettings(w);
}

function closeWin(id) {
  const w=openWins[id]; if(!w) return;
  w.remove(); delete openWins[id];
  const dot=document.getElementById('dot-'+id); if(dot) dot.classList.remove('visible');
}

function focusWin(w) {
  Object.values(openWins).forEach(x=>x.classList.remove('focused'));
  w.classList.add('focused'); w.style.zIndex=++zCtr;
  const names={finder:'Finder',terminal:'Terminal',files:'Files',editor:'Text Editor',settings:'Settings'};
  document.getElementById('active-app-name').textContent=names[w.dataset.id]||'Finder';
}

